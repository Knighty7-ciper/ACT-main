{
  "name": "act-payment-backend",
  "version": "1.0.0",
  "description": "ACT Token Payment Backend Service with PesaPal Integration",
  "main": "api/payment-service.js",
  "scripts": {
    "start": "node api/payment-service.js",
    "dev": "nodemon api/payment-service.js",
    "start:server": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "migration:run": "ts-node -r tsconfig-paths/register src/run-migrations.ts",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration",
    "test:unit": "jest --testPathPattern=unit",
    "lint": "eslint api/",
    "format": "prettier --write api/"
  },
  "keywords": [
    "act",
    "token",
    "payment",
    "pesapal",
    "africa",
    "mobile-money"
  ],
  "author": "MiniMax Agent",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.20",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.7",
    "@nestjs/platform-socket.io": "^10.4.7",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.7",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "stellar-sdk": "^11.2.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.2",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/testing": "^10.4.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.5",
    "@types/node": "^20.19.24",
    "@types/uuid": "^10.0.0",
    "csurf": "^1.11.0",
    "passport-jwt": "^4.0.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/act-payment-backend.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/act-payment-backend/issues"
  },
  "homepage": "https://github.com/yourusername/act-payment-backend#readme"
