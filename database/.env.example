# =============================================================================
# ACT Coin Platform — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development, and set the same keys in
# your Vercel project (Project Settings → Environment Variables).
# =============================================================================

# -----------------------------------------------------------------------------
# Database — REQUIRED
# Get this from your Neon (or Supabase / Vercel Postgres) dashboard.
# On Vercel, the Neon integration will auto-inject this for you.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# -----------------------------------------------------------------------------
# Better Auth — REQUIRED
# Generate the secret with:  openssl rand -base64 32
# MUST be set manually in Vercel (no auto-injection).
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=replace-me-with-output-of-openssl-rand-base64-32

# Optional — only needed if NOT deploying to Vercel.
# On Vercel, VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL are auto-set.
# BETTER_AUTH_URL=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
